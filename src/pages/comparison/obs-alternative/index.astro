---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Hero from '../../../components/Hero.astro';
import ComparisonTable from '../../../components/ComparisonTable.astro';
import DetailSections from '../../../components/DetailSections.astro';
import Verdict from '../../../components/Verdict.astro';
import FAQ from '../../../components/FAQ.astro';
import CTA from '../../../components/CTA.astro';
import RelatedContent from '../../../components/RelatedContent.astro';
import Footer from '../../../components/Footer.astro';
import { allComparisons } from '../../../data/comparisons';

const page = allComparisons.find((c) => c.slug === 'medal-vs-obs')!;
---

<Layout
  title="Best OBS Alternative for Game Clipping (2026) — Medal"
  description="Looking for an OBS alternative that clips, edits, and shares your gaming highlights instantly? Medal is the easiest OBS replacement for PC gamers — free, lightweight, and built for clips."
  canonicalPath="/medal-vs-obs/"
  faqSchema={page.faqs}
>
  <Header currentSlug={page.slug} />

  <main>
    <Hero
      competitor={page.competitor}
      subtitle="Looking for something simpler than OBS for clipping your best gaming moments? Medal gives you instant replay, auto-clipping, a built-in editor, and one-click sharing — no configuration required."
      competitorUrl={page.competitorUrl}
    />
    <Verdict verdict={page.verdict} />
    <ComparisonTable rows={page.comparisonRows} competitorName={page.competitorShort} />
    <DetailSections sections={page.detailSections} />
    <FAQ faqs={page.faqs} />
    <RelatedContent currentSlug={page.slug} />
    <CTA />
  </main>

  <Footer currentSlug={page.slug} />
</Layout>
