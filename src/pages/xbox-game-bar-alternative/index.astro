---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import DetailSections from '../../components/DetailSections.astro';
import Verdict from '../../components/Verdict.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import Footer from '../../components/Footer.astro';
import { allComparisons } from '../../data/comparisons';

const page = allComparisons.find((c) => c.slug === 'medal-vs-xbox-game-bar')!;
---

<Layout
  title="Best Xbox Game Bar Alternative for Game Recording (2026) — Medal"
  description="Xbox Game Bar not cutting it? Medal is the best free alternative — auto-clips your highlights, has a real editor, and shares clips instantly. No manual file management."
  canonicalPath="/medal-vs-xbox-game-bar/"
  faqSchema={page.faqs}
>
  <Header currentSlug={page.slug} />

  <main>
    <Hero
      competitor={page.competitor}
      subtitle="Xbox Game Bar comes pre-installed but stops at basic recording. Medal is a free upgrade that adds auto-clipping, instant sharing, a real editor, and a mobile app — everything Game Bar is missing."
      competitorUrl={page.competitorUrl}
    />
    <Verdict verdict={page.verdict} />
    <ComparisonTable rows={page.comparisonRows} competitorName={page.competitorShort} />
    <DetailSections sections={page.detailSections} />
    <FAQ faqs={page.faqs} />
    <RelatedContent currentSlug={page.slug} />
    <CTA />
  </main>

  <Footer currentSlug={page.slug} />
</Layout>
