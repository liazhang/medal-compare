---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import DetailSections from '../../components/DetailSections.astro';
import Verdict from '../../components/Verdict.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import Footer from '../../components/Footer.astro';
import { allComparisons } from '../../data/comparisons';

const page = allComparisons.find((c) => c.slug === 'medal-vs-outplayed')!;
---

<Layout
  title="Best Outplayed Alternative Without Overwolf (2026) — Medal"
  description="Tired of Overwolf running in the background? Medal is a standalone Outplayed alternative with auto-clipping, instant sharing, a real editor, and no bloatware. Free to use."
  canonicalPath="/medal-vs-outplayed/"
  faqSchema={page.faqs}
>
  <Header currentSlug={page.slug} />

  <main>
    <Hero
      competitor={page.competitor}
      subtitle="Outplayed requires Overwolf running in the background. Medal is standalone — auto-clips your highlights, gives you instant share links, and runs lighter on your system. No extra platform needed."
      competitorUrl={page.competitorUrl}
    />
    <Verdict verdict={page.verdict} />
    <ComparisonTable rows={page.comparisonRows} competitorName={page.competitorShort} />
    <DetailSections sections={page.detailSections} />
    <FAQ faqs={page.faqs} />
    <RelatedContent currentSlug={page.slug} />
    <CTA />
  </main>

  <Footer currentSlug={page.slug} />
</Layout>
